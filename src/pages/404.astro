---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | Mellon Voice" description="The page you're looking for doesn't exist." noindex={true}>
  <main style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; text-align: center; padding: 2rem;">
    <h1 style="font-size: 4rem; margin-bottom: 0.5rem;">404</h1>
    <p style="font-size: 1.25rem; margin-bottom: 2rem; opacity: 0.7;">This page doesn't exist.</p>
    <a href="/" style="color: var(--accent-color, #6366f1); text-decoration: underline;">Back to home</a>
  </main>
</BaseLayout>
